# ============================================================
# CHAINRND — CONFIGURATION
# ============================================================
# Setup:
#   1. Copy this file to ".env" (without .example)
#   2. Fill in the values below
#   3. NEVER commit .env to GitHub (it's in .gitignore).
#      For GitHub Actions, use Settings -> Secrets/Variables instead.

# --- Required ---
# Get a free key: https://etherscan.io/myapikey
# (BscScan / PolygonScan / Arbiscan have their own free keys too —
#  most explorers accept the same key format per Etherscan V2 API,
#  but if yours doesn't, set EXPLORER_BASE_URL below per chain.)
EXPLORER_API_KEY=your_explorer_api_key_here

# Optional override — if unset, chosen automatically from --chain
# EXPLORER_BASE_URL=https://api.etherscan.io/api
# COINGECKO_PLATFORM=ethereum

# --- Whale / Smart Money Thresholds ---
WHALE_THRESHOLD_TOKENS=100000
ACCUMULATION_MIN_BUYS=4
ACCUMULATION_WINDOW_DAYS=7
COORDINATED_WINDOW_MINUTES=10
COORDINATED_MIN_WALLETS=3
FRESH_WALLET_BUY_THRESHOLD=50000
EXCHANGE_UNIQUE_SENDER_THRESHOLD=50
TOP_N_WALLETS_FOR_DEEP_ANALYSIS=100
WALLET_CACHE_TTL_DAYS=7

# --- Smart Money Score Weights (should sum to ~1.0) ---
WEIGHT_PNL=0.35
WEIGHT_ACCUMULATION=0.20
WEIGHT_CROSS_TOKEN=0.15
WEIGHT_TIMING=0.15
WEIGHT_COORDINATED_FRESH=0.15

# --- Exchange Flow Tracker ---
LARGE_FLOW_ALERT_THRESHOLD=100000

# Known exchange hot-wallets, comma-separated (optional, boosts accuracy)
KNOWN_EXCHANGE_ADDRESSES=
